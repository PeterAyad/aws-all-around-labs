{
  "Comment": "Thumbnail Workflow — resize image to 150x150",
  "StartAt": "ProcessThumbnail",
  "States": {
    "ProcessThumbnail": {
      "Type": "Task",
      "Resource": "arn:aws:states:::lambda:invoke",
      "Parameters": {
        "FunctionName": "REPLACE_WITH_LAMBDA_ARN",
        "Payload": {
          "bucket.$": "$.detail.bucket.name",
          "key.$":    "$.detail.object.key",
          "mode":     "thumbnail"
        }
      },
      "ResultPath": "$.result",
      "End": true
    }
  }
}
